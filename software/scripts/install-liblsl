#!/usr/bin/env bash
set -e

echo "Building and installing liblsl from source..."
sudo apt install -y cmake g++ git

git clone https://github.com/sccn/liblsl.git /tmp/liblsl
cd /tmp/liblsl
mkdir build && cd build
cmake ..
cmake --build . --config Release
sudo cmake --install .

sudo ldconfig

# Copy into pylsl's package directory so it can find it
PYLSL_LIB=$(python -c "import pylsl.lib as l; import os; print(os.path.dirname(l.__file__))")
sudo cp /usr/local/lib/liblsl.so* "$PYLSL_LIB/"

echo "liblsl installed to /usr/local/lib and copied to $PYLSL_LIB"